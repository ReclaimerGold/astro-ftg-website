---
interface Props {
	title: string;
	description: string;
	primaryCtaLabel?: string;
	primaryCtaHref?: string;
	secondaryCtaLabel?: string;
	secondaryCtaHref?: string;
	eyebrow?: string;
	imageSrc?: string;
	imageAlt?: string;
}

const {
	title,
	description,
	primaryCtaLabel = 'Get My Free Quote',
	primaryCtaHref = '/contact',
	secondaryCtaLabel,
	secondaryCtaHref = '#',
	eyebrow = 'Websites That Bring In Calls',
	imageSrc = '/placeholder-photo.svg',
	imageAlt = 'Placeholder service image',
} = Astro.props;

const benefits = [
	{
		label: 'A custom site that loads fast and looks sharp on phones',
		icon: 'phone',
	},
	{
		label: 'Hosting and maintenance handled for you each month',
		icon: 'server',
	},
	{
		label: 'Built-in SEO setup so local customers can find you',
		icon: 'search',
	},
	{
		label: 'A clear two-week process with a first look in week one',
		icon: 'calendar',
	},
] as const;
---

<section class="layout-section border-b border-slate-200 bg-white pt-8 md:pt-12">
	<div class="layout-container grid gap-10 lg:grid-cols-12 lg:items-stretch lg:gap-12">
		<div class="flex flex-col gap-5 lg:col-span-7 lg:min-h-0 lg:justify-center lg:py-2">
			<p class="text-eyebrow">{eyebrow}</p>
			<h1>{title}</h1>
			<p class="max-w-prose text-base leading-relaxed text-slate-600">{description}</p>
			<div class="flex flex-wrap gap-3">
				<a class="btn btn-primary" href={primaryCtaHref}>{primaryCtaLabel}</a>
				{secondaryCtaLabel && (
					<a class="btn btn-secondary" href={secondaryCtaHref}>{secondaryCtaLabel}</a>
				)}
			</div>

			<ul
				class="m-0 grid list-none grid-cols-2 gap-3 p-0 sm:grid-cols-4 lg:gap-4"
				aria-label="What you get"
			>
				{
					benefits.map((item) => (
						<li class="flex flex-col items-center gap-2 text-center">
							<span
								class="flex size-11 shrink-0 items-center justify-center rounded-lg bg-emerald-50 text-emerald-700 ring-1 ring-emerald-100"
								aria-hidden="true"
							>
								{item.icon === 'phone' && (
									<svg class="size-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3"
										/>
									</svg>
								)}
								{item.icon === 'server' && (
									<svg class="size-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3V6.75a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3v4.5a3 3 0 0 1-3 3m-16.5 0a3 3 0 0 0 3 3h13.5a3 3 0 0 0 3-3m-19.5 0v4.125c0 1.036.84 1.875 1.875 1.875H9a3 3 0 0 0 3 3v2.25a1.5 1.5 0 0 0 1.5 1.5h5.25a1.5 1.5 0 0 0 1.5-1.5V21a3 3 0 0 0 3-3v-4.125"
										/>
									</svg>
								)}
								{item.icon === 'search' && (
									<svg class="size-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"
										/>
									</svg>
								)}
								{item.icon === 'calendar' && (
									<svg class="size-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5a2.25 2.25 0 0 0 2.25-2.25m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5a2.25 2.25 0 0 1 2.25 2.25v7.5"
										/>
									</svg>
								)}
							</span>
							<span class="text-xs font-medium leading-snug text-slate-600">{item.label}</span>
						</li>
					))
				}
			</ul>
		</div>
		<div
			class="flex min-h-0 flex-col overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm lg:col-span-5 lg:h-full"
		>
			<div
				class="relative aspect-[4/3] min-h-[200px] w-full overflow-hidden bg-slate-100 lg:aspect-auto lg:min-h-0 lg:flex-1"
			>
				<img class="img-cover" src={imageSrc} alt={imageAlt} loading="lazy" width="800" height="600" />
			</div>
		</div>
	</div>
</section>
