---
import Layout from '../layouts/Layout.astro';
import SupportForm from '../components/SupportForm.astro';

const status = Astro.url.searchParams.get('status');

const statusMessage =
	status === 'success'
		? 'Thanks. Your support request is in and we will follow up shortly.'
		: status === 'invalid'
			? 'Please fill in the required support fields and try again.'
			: status === 'error'
				? 'Something went wrong while sending your request. Please try again in a minute.'
				: null;

const supportFocus = [
	'Technical troubleshooting and uptime issues',
	'Content and layout edits for existing pages',
	'Design refinements and update requests',
] as const;
---

<Layout
	title="Support | Digmar Web Solutions"
	description="Request technical support or design updates from Digmar Web Solutions. Submit your issue details and we will respond quickly."
	path="/support"
>
	<section class="layout-section border-b border-slate-200 bg-white">
		<div class="layout-container max-w-3xl">
			<p class="text-eyebrow">Support</p>
			<h1 class="mt-2">Need a technical fix or design update?</h1>
			<p class="mt-4 text-base leading-relaxed text-slate-600">
				Use this form for website support, edits, and design requests. Share enough detail and we can move quickly.
			</p>
		</div>
	</section>
	<section class="layout-section border-t border-slate-200 bg-slate-50">
		<div class="layout-container grid items-start gap-8 lg:grid-cols-2 lg:gap-10">
			<div class="flex min-h-0 flex-col gap-4">
				<h2 class="m-0 text-xl font-bold text-slate-900 sm:text-2xl">What this support page is for</h2>
				<ul class="m-0 grid list-none gap-3 p-0">
					{
						supportFocus.map((item) => (
							<li class="card-surface p-4 sm:p-5">
								<p class="m-0 text-sm font-medium leading-relaxed text-slate-700 sm:text-base">{item}</p>
							</li>
						))
					}
				</ul>
			</div>
			<div class="flex flex-col gap-4 lg:justify-center">
				{
					statusMessage && (
						<p
							class:list={[
								'card-surface border-2 text-sm leading-relaxed',
								status === 'success' && 'border-emerald-500 bg-emerald-50 text-emerald-900',
								(status === 'invalid' || status === 'error') && 'border-amber-500 bg-amber-50 text-amber-950',
							]}
						>
							{statusMessage}
						</p>
					)
				}
				<SupportForm />
			</div>
		</div>
	</section>
</Layout>
