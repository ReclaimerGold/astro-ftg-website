---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Privacy Policy | Digmar Web Solutions"
	description="Read how Digmar Web Solutions collects, uses, and protects data for website visitors and contact form submissions."
	path="/privacy-policy"
>
	<section class="layout-section border-b border-slate-200 bg-white">
		<div class="layout-container max-w-3xl">
			<p class="text-eyebrow">Privacy Policy</p>
			<h1 class="mt-2">Privacy and data handling at Digmar Web Solutions</h1>
			<p class="mt-2 text-sm text-slate-600">Last updated: April 20, 2026</p>
		</div>
	</section>
	<section class="layout-section">
		<div class="layout-container grid items-center gap-8 lg:grid-cols-2 lg:gap-12">
			<div class="card-surface flex flex-col gap-3">
				<p class="text-eyebrow">Your Information</p>
				<h2>Clear, simple privacy practices</h2>
				<p class="m-0 text-base leading-relaxed text-slate-600">
					We keep this policy straightforward so you understand what we collect, why we collect it, and how we protect it.
				</p>
			</div>
			<div class="relative aspect-[4/3] overflow-hidden rounded-lg border border-slate-200 bg-slate-100">
				<img
					class="img-cover"
					src="/placeholder-photo.svg"
					alt="Privacy policy visual placeholder"
					loading="lazy"
					width="800"
					height="600"
				/>
			</div>
		</div>
	</section>

	<section class="layout-section border-t border-slate-200 bg-white">
		<div class="layout-container flex max-w-3xl flex-col gap-6">
			<article class="card-surface flex flex-col gap-2">
				<h2>Information we collect</h2>
				<p class="m-0 text-sm leading-relaxed text-slate-600">
					When you use our contact form, we collect the details you submit, such as your name, email address, company, project
					information, and message content.
				</p>
			</article>
			<article class="card-surface flex flex-col gap-2">
				<h2>How we use your information</h2>
				<p class="m-0 text-sm leading-relaxed text-slate-600">
					We use submitted information to respond to your request, provide project information, and improve service quality. We do not
					sell your personal data.
				</p>
			</article>
			<article class="card-surface flex flex-col gap-2">
				<h2>Hosting, analytics, and cookies</h2>
				<p class="m-0 text-sm leading-relaxed text-slate-600">
					We may use analytics and tracking tools to understand site performance and improve user experience. Where used, cookies and
					similar technologies may store basic usage metadata.
				</p>
			</article>
			<article class="card-surface flex flex-col gap-2">
				<h2>Email processing and form delivery</h2>
				<p class="m-0 text-sm leading-relaxed text-slate-600">
					Form submissions are routed through our configured email delivery provider to send messages to our team inbox for response and
					service follow-up.
				</p>
			</article>
			<article class="card-surface flex flex-col gap-2">
				<h2>Data retention and security</h2>
				<p class="m-0 text-sm leading-relaxed text-slate-600">
					We retain submitted data only as long as needed for communication and service operations, and we apply reasonable
					safeguards to protect that information.
				</p>
			</article>
			<article class="card-surface flex flex-col gap-2">
				<h2>Your rights and contact</h2>
				<p class="m-0 text-sm leading-relaxed text-slate-600">
					If you need to access, update, or request deletion of your data, contact us through the <a
						class="font-medium text-emerald-800 underline hover:text-emerald-900"
						href="/contact">contact page</a
					>.
				</p>
			</article>
		</div>
	</section>
</Layout>
