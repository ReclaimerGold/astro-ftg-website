---
import ContactForm from '../components/ContactForm.astro';
import Layout from '../layouts/Layout.astro';

const status = Astro.url.searchParams.get('status');

const statusMessage =
	status === 'success'
		? 'Thanks. We got your message and will reach out shortly.'
		: status === 'invalid'
			? 'Please fill in the required fields and try again.'
			: status === 'error'
				? 'Something went wrong while sending your message. Please try again in a minute.'
				: null;

const nextSteps = [
	'We review your business goals and current website',
	'We recommend the right monthly plan for your pace',
	'We map a launch path you can understand in minutes',
] as const;
---

<Layout
	title="Contact Digmar Web Solutions | Get a Free Quote"
	description="Request a free quote from Digmar Web Solutions for a faster, lead-focused website and hands-free monthly management."
	path="/contact"
>
	<section class="layout-section border-b border-slate-200 bg-white">
		<div class="layout-container max-w-3xl">
			<p class="text-eyebrow">Contact</p>
			<h1 class="mt-2">Let us talk about getting you more local leads</h1>
			<p class="mt-4 text-base leading-relaxed text-slate-600">
				Tell us about your business and service area. We will send a straightforward recommendation and quote.
			</p>
		</div>
	</section>
	<section class="layout-section">
		<div class="layout-container grid items-center gap-8 lg:grid-cols-5 lg:gap-10">
			<div class="relative aspect-[4/3] overflow-hidden rounded-lg border border-slate-200 bg-slate-100 lg:col-span-2">
				<img
					class="img-cover"
					src="/placeholder-photo.svg"
					alt="Customer consultation placeholder"
					loading="lazy"
					width="640"
					height="480"
				/>
			</div>
			<div class="card-surface flex flex-col gap-3 lg:col-span-3">
				<p class="text-eyebrow">Quick Response</p>
				<h2>Send your details and we will map next steps fast</h2>
				<p class="m-0 text-base leading-relaxed text-slate-600">
					No long forms and no confusing process. Tell us what you need, and we will come back with a clear recommendation and quote
					path.
				</p>
			</div>
		</div>
	</section>
	<section class="layout-section border-t border-slate-200 bg-slate-50">
		<div class="layout-container grid items-stretch gap-8 lg:grid-cols-2 lg:gap-10">
			<div class="flex min-h-0 flex-col gap-5">
				<h2 class="m-0 shrink-0 text-xl font-bold text-slate-900 sm:text-2xl">What happens next</h2>
				<ol class="m-0 flex list-none flex-col gap-3 p-0" aria-label="Steps after you contact us">
					{
						nextSteps.map((label, index) => (
							<li class="card-surface flex gap-4 p-4 sm:gap-5 sm:p-5">
								<span
									class="flex size-12 shrink-0 items-center justify-center rounded-lg bg-emerald-50 text-emerald-700 ring-1 ring-emerald-100 sm:size-14"
									aria-hidden="true"
								>
									{index === 0 && (
										<svg class="size-7 sm:size-8" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z"
											/>
										</svg>
									)}
									{index === 1 && (
										<svg class="size-7 sm:size-8" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941"
											/>
										</svg>
									)}
									{index === 2 && (
										<svg class="size-7 sm:size-8" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"
											/>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
											/>
										</svg>
									)}
								</span>
								<div class="flex min-w-0 flex-1 flex-col justify-center gap-1 pt-0.5">
									<p class="text-eyebrow m-0 text-[0.65rem]">Step {index + 1}</p>
									<p class="m-0 text-sm font-medium leading-relaxed text-slate-700 sm:text-base">{label}</p>
								</div>
							</li>
						))
					}
				</ol>
			</div>
			<div class="flex flex-col gap-4 lg:justify-center">
				{
					statusMessage && (
						<p
							class:list={[
								'card-surface border-2 text-sm leading-relaxed',
								status === 'success' && 'border-emerald-500 bg-emerald-50 text-emerald-900',
								(status === 'invalid' || status === 'error') && 'border-amber-500 bg-amber-50 text-amber-950',
							]}
						>
							{statusMessage}
						</p>
					)
				}
				<ContactForm />
			</div>
		</div>
	</section>
</Layout>
